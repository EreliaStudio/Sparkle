# Doxyfile configuration file

# Project name
PROJECT_NAME = "Sparkle"

# Project version
PROJECT_NUMBER = 1.0

# The root directory of the source code
INPUT = ./Sparkle/src

# Sorting classes by full name, including namespace and parent class
SORT_BY_SCOPE_NAME=YES

# Remove incomplete function documentation
WARN_IF_INCOMPLETE_DOC=NO

# Recursively include all subdirectories
RECURSIVE = YES

# Output directory for the generated documentation
OUTPUT_DIRECTORY = docs

# Output format
GENERATE_HTML = YES
GENERATE_XML = YES

WARN_LOGFILE = doxygen_warnings.log

EXCLUDE_PATTERNS = */playground/* */external_libraries/*
