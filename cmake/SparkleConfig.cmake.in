@PACKAGE_INIT@

find_package(GLEW REQUIRED)

set(SPARKLE_INCLUDE_DIRS "@SPARKLE_INCLUDE_DIRECTORY@" ${GLEW_INCLUDE_DIRS})
set(SPARKLE_LIBRARY_DIRS "@SPARKLE_LIBRARY_DIRECTORY@" ${GLEW_LIBRARY_DIRS})

set(SPARKLE_LIBRARIES Sparkle OpenGL32.lib GLEW::GLEW)

include("@CMAKE_INSTALL_PREFIX@/lib/cmake/Sparkle/SparkleTargets.cmake")