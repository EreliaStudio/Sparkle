@PACKAGE_INIT@

find_package(GLEW REQUIRED)

set(SPARKLE_INCLUDE_DIRS "@SPARKLE_INCLUDE_DIRECTORY@")

set(SPARKLE_LIBRARY_DIRS "@SPARKLE_LIBRARY_DIRECTORY@")

set(SPARKLE_LIBRARY_DIRS "@SPARKLE_LIBRARY_DIRECTORY@" ${GLEW_LIBRARY_DIRS})
set(SPARKLE_LIBRARIES Sparkle ${GLEW_LIBRARIES})

include("${CMAKE_CURRENT_LIST_DIR}/SparkleTargets.cmake")